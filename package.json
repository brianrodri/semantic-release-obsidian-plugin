{
    "name": "semantic-release-obsidian-plugin",
    "version": "1.0.0",
    "description": "semantic-release plugin to automate release publishing for Obsidian plugins",
    "type": "module",
    "main": "index.js",
    "repository": "https://github.com/brianrodri/semantic-release-obsidian-plugin.git",
    "author": "Brian Rodriguez <brian@brianrodri.com>",
    "license": "MIT",
    "scripts": {
        "prepare": "husky",
        "lint": "eslint . && prettier --check .",
        "lint:commit": "commitlint --edit",
        "format": "prettier --write .",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "watch": "vitest --watch",
        "watch:coverage": "vitest --watch --coverage"
    },
    "dependencies": {
        "aggregate-error": "^5.0.0",
        "execa": "^9.6.1"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.2.1",
        "@commitlint/config-conventional": "^21.2.0",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@vitest/coverage-v8": "^4.1.10",
        "commitlint": "^21.2.1",
        "eslint": "^10.6.0",
        "husky": "^9.1.7",
        "prettier": "^3.9.5",
        "vitest": "^4.1.10"
    },
    "peerDependencies": {
        "semantic-release": "^25.0.2"
    },
    "allowScripts": {
        "fsevents@2.3.3": true
    }
}
